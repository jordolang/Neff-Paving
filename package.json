{
  "name": "neff-paving",
  "version": "1.0.0",
  "description": "Professional paving services website",
  "type": "module",
  "main": "src/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:github": "vite build --mode github",
    "build:vercel": "vite build --mode vercel",
    "build:optimized": "node scripts/deploy-optimized.js",
    "build:optimized:github": "cross-env DEPLOY_PLATFORM=github node scripts/deploy-optimized.js",
    "build:optimized:vercel": "cross-env DEPLOY_PLATFORM=vercel node scripts/deploy-optimized.js",
    "vercel-build": "cross-env VERCEL=1 VERCEL_ENV=production DEPLOY_PLATFORM=vercel VITE_PLATFORM=vercel node scripts/deploy-optimized.js",
    "verify:build": "node scripts/verify-build.js",
    "verify:vercel": "node scripts/verify-vercel-build.js",
    "test:vercel": "node scripts/test-vercel-config.js",
    "preview": "vite preview",
    "deploy": "npm run build:github && gh-pages -d dist",
    "deploy:github": "npm run build:github && gh-pages -d dist",
    "deploy:vercel": "npm run build:vercel",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:sw": "node scripts/test-sw.js",
    "verify:assets": "node verify-assets.js",
    "audit:performance": "node scripts/run-lighthouse.js"
  },
  "keywords": [
    "paving",
    "construction",
    "website",
    "vite"
  ],
  "author": "Neff Paving",
  "license": "ISC",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "@googlemaps/js-api-loader": "^2.1.1",
    "@stripe/stripe-js": "^7.4.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "animate.css": "^4.1.1",
    "aos": "^2.3.4",
    "decap-cms-app": "^3.3.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@vitest/coverage-v8": "^1.6.0",
    "@vitest/ui": "^1.6.0",
    "cross-env": "^10.1.0",
    "fs-extra": "^11.3.5",
    "gh-pages": "^6.3.0",
    "happy-dom": "^20.10.6",
    "sharp": "^0.35.2",
    "terser": "^5.48.0",
    "vite": "^8.0.16",
    "vitest": "^1.6.0"
  }
}
